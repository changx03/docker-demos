<?xml version="1.0" encoding="UTF-8"?>
<CycloneDDS xmlns="https://cdds.io/config"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd"
>
    <Domain id="any">
        <General>
            <!-- Multicast only on discovery -->
            <AllowMulticast>spdp</AllowMulticast>
            <Interfaces>
                <NetworkInterface address="127.0.0.1" allow_multicast="false" />
                <NetworkInterface name="eno1" />
            </Interfaces>
            <Transport>udp</Transport> <!-- MultipleReceiveThreads only works with connectionless transport (UDP) -->
            <MaxMessageSize>14720B</MaxMessageSize> <!-- Cannot be larger than MTU (1500) (Default=14720B) -->
        </General>
        <Internal>
            <MultipleReceiveThreads>true</MultipleReceiveThreads>
            <!-- a writer with QoS settings transport_priority >= SynchronousDeliveryPriorityThreshold and 
            a latency_budget at most this element's value will be delivered synchronously from the "recv" thread, 
            all others will be delivered asynchronously through delivery queues. 
            This reduces latency at the expense of aggregate bandwidth. -->
            <SynchronousDeliveryLatencyBound>5ms</SynchronousDeliveryLatencyBound>
        </Internal>
        <Sizing>
            <ReceiveBufferChunkSize>16MB</ReceiveBufferChunkSize>
            <ReceiveBufferSize>64MB</ReceiveBufferSize>
        </Sizing>
    </Domain>
</CycloneDDS>
